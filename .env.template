# ============================================================
# Modèle de configuration — copier vers `.env` puis adapter.
#   cp .env.template .env
# Le fichier `.env` est ignoré par git (ne jamais committer de secrets).
# ============================================================

# ------------------------------------------------------------
# Base de données (PostgreSQL)
# ------------------------------------------------------------
# Chaîne de connexion lue par l'app (src/config/env.ts) et par Prisma
# (prisma.config.ts). Format : postgres://USER:PASSWORD@HOST:5432/DBNAME
#
# En dev local, démarrer la base avec :
#   docker compose -f docker-compose.dev.yml up -d
DATABASE_URL=postgres://dogapi:dogapi@localhost:5432/dogapi

# ============================================================
# Identifiants Postgres — docker-compose.yml (prod) ET docker-compose.dev.yml (dev).
# En prod, POSTGRES_PASSWORD est OBLIGATOIRE (docker-compose.yml échoue sinon).
# ============================================================
POSTGRES_USER=dogapi
POSTGRES_PASSWORD=dogapi
POSTGRES_DB=dogapi

# Port public exposé par nginx (reverse proxy, prod).
NGINX_PORT=80

# ------------------------------------------------------------
# Réglages applicatifs (lus par src/config/env.ts ; défauts entre parenthèses).
# ------------------------------------------------------------
# Secret de signature des JWT (HS256). Min 16 caractères ; 32+ recommandés. openssl rand -hex 32
JWT_SECRET=change-me-please-32-chars-minimum-xxxx
# Port d'écoute de l'API (3000)
PORT=3000
# Durée de validité des JWT (1d) — ex. "1d", "12h", "30m", ou un nombre de secondes
JWT_EXPIRES_IN=1d
# Coût bcrypt, 4-15 (10)
BCRYPT_ROUNDS=10
# Origine(s) CORS autorisée(s), séparées par des virgules (URL du frontend en prod).
CORS_ORIGIN=http://localhost
# Taille max d'upload en octets (5242880 = 5 Mo) — garder < client_max_body_size nginx (6m)
UPLOAD_MAX_SIZE=5242880
# Rate limiting : fenêtre globale (900000 ms = 15 min) et quota global (100 req/fenêtre)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Quota plus strict sur /auth (10 req/fenêtre) — anti brute-force
AUTH_RATE_LIMIT_MAX=10
