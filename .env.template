# ============================================================
# Modèle de configuration — copier vers `.env` puis adapter.
#   cp .env.template .env
# Le fichier `.env` est ignoré par git (ne jamais committer de secrets).
# ============================================================

# ------------------------------------------------------------
# Base de données
# ------------------------------------------------------------
# Moteur de base. Pilote À LA FOIS :
#   - l'adaptateur Prisma au runtime (src/lib/prisma.ts)
#   - le `provider` du schéma au generate/db push (prisma/set-provider.mjs,
#     lancé par les scripts npm prisma:generate / prisma:migrate / prisma:deploy)
# Valeurs acceptées : sqlite | postgresql
DATABASE_PROVIDER=sqlite

# Chaîne de connexion, cohérente avec DATABASE_PROVIDER :
#   - sqlite      : file:./dev.db
#   - postgresql  : postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=file:./dev.db

# --- Exemple PROD (Postgres) — décommenter et adapter -------
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgres://taskapi:change-me@localhost:5432/taskapi

# ------------------------------------------------------------
# Authentification
# ------------------------------------------------------------
# Secret de signature des JWT (HS256). Minimum 16 caractères ; 32+ recommandés.
# Générer : openssl rand -hex 32
JWT_SECRET=change-me-please-32-chars-minimum-xxxx

# ============================================================
# Docker Compose (déploiement prod) — `docker compose up`
# Dans ce contexte, le conteneur `app` reçoit automatiquement
# DATABASE_PROVIDER=postgresql et DATABASE_URL (construite ci-dessous) ;
# il n'est pas nécessaire de les définir ici pour l'app.
# ============================================================
# Identifiants Postgres (service `postgres`) — POSTGRES_PASSWORD est OBLIGATOIRE.
POSTGRES_USER=taskapi
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=taskapi

# Port public exposé par nginx (reverse proxy).
NGINX_PORT=80

# ------------------------------------------------------------
# Réglages applicatifs (lus par src/config/env.ts ; défauts entre parenthèses).
# Optionnels en local (les défauts s'appliquent) ; fournis par docker-compose en prod.
# ------------------------------------------------------------
# Port d'écoute de l'API (3000)
PORT=3000
# Durée de validité des JWT (1d) — ex. "1d", "12h", "30m", ou un nombre de secondes
JWT_EXPIRES_IN=1d
# Coût bcrypt, 4-15 (10)
BCRYPT_ROUNDS=10
# Taille max d'upload en octets (5242880 = 5 Mo) — garder < client_max_body_size nginx (6m)
UPLOAD_MAX_SIZE=5242880
# Rate limiting : fenêtre globale (900000 ms = 15 min) et quota global (100 req/fenêtre)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Quota plus strict sur /auth (10 req/fenêtre) — anti brute-force
AUTH_RATE_LIMIT_MAX=10
