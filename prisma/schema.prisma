// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // Le projet est en CommonJS ("type": "commonjs") : on force le client en CJS
  // pour qu'il compile avec tsc et tourne sous `node dist/...`.
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Dog {
  id        Int     @id @default(autoincrement())
  name      String
  active    Boolean @default(false)
  // Nom du fichier stocké (uploads/) lié au chien via POST /dogs/:id/upload.
  // Nullable : un chien peut ne pas avoir de pièce jointe.
  attachment String?
  // Propriétaire du chien. Toutes les opérations /dogs sont scoppées à
  // l'utilisateur authentifié (cf. dogs.service). Cascade : supprimer un
  // utilisateur supprime ses chiens.
  ownerId   Int
  owner     User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  dogs      Dog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}